{
  "title": "Net Probe Exporter",
  "description": "Dashboard for net-probe-exporter monitoring",
  "tags": ["net-probe", "prometheus", "exporter"],
  "schemaVersion": 39,
  "version": 3,
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "site",
        "type": "query",
        "query": {
          "query": "label_values(net_probe_up, target)",
          "refId": "Prometheus-site-var"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "label": "Site",
        "allValue": ".*",
        "includeAll": true,
        "multi": true,
        "sort": 1,
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Service Status",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "net_probe_up{target=~\"$site\"}",
          "legendFormat": "{{target}} ({{type}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "displayMode": "color-text"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ]
        }
      },
      "options": {
        "sortBy": [
          { "displayName": "Value" }
        ]
      }
    },
    {
      "id": 2,
      "title": "Average Latency by Target",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "avg(net_probe_latency_ms{target=~\"$site\"}) by (target)",
          "legendFormat": "{{target}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "showPoints": "auto"
          }
        }
      },
      "options": {
        "legend": {
          "showLegend": true,
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 3,
      "title": "HTTP Status Code",
      "type": "gauge",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "net_probe_http_status_code{target=~\"$site\"}",
          "legendFormat": "{{target}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 600,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 400 }
            ]
          },
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 4,
      "title": "Total Scrapes",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(net_probe_scrapes_total{target=~\"$site\"})",
          "legendFormat": "Scrapes",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "textMode": "auto"
      }
    },
    {
      "id": 5,
      "title": "Scrapes by Result",
      "type": "piechart",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "net_probe_scrapes_total{target=~\"$site\"}",
          "legendFormat": "{{target}} ({{result}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": []
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": ["sum"],
          "fields": "",
          "values": false
        },
        "pieType": "donut",
        "displayLabels": ["name", "percent"],
        "legend": {
          "placement": "right",
          "values": ["value", "percent"]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 6,
      "title": "SSL Days Until Expiry",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "net_probe_ssl_days_until_expiry{target=~\"$site\"}",
          "legendFormat": "{{target}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 7 },
              { "color": "yellow", "value": 15 },
              { "color": "green", "value": 30 }
            ]
          },
          "mappings": []
        }
      },
      "options": {
        "sortBy": [
          { "displayName": "Value" }
        ]
      }
    },
    {
      "id": 7,
      "title": "Uptime (7 days)",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "avg_over_time(net_probe_up{target=~\"$site\",type=\"http\"}[7d]) * 100",
          "legendFormat": "{{target}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 95 },
              { "color": "yellow", "value": 99 },
              { "color": "green", "value": 99.9 }
            ]
          },
          "mappings": []
        }
      },
      "options": {
        "sortBy": [
          { "displayName": "Value" }
        ]
      }
    },
    {
      "id": 8,
      "title": "Current Latency",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "net_probe_latency_ms{target=~\"$site\"}",
          "legendFormat": "{{target}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          },
          "mappings": []
        }
      },
      "options": {
        "sortBy": [
          { "displayName": "Value" }
        ]
      }
    }
  ]
}
